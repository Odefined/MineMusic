{
  "name": "minemusic",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:test": "tsc -p tsconfig.test.json",
    "mcp:minemusic:dev": "npm run build:test && node .tmp-test/src/surfaces/mcp/stdio-dev.js",
    "server:minemusic": "npm run build:test && sh -c 'set -a; [ ! -f .env ] || . ./.env; set +a; exec node .tmp-test/src/server/index.js'",
    "smoke:netease": "npm run build:test && node .tmp-test/test/live/netease-source-smoke.js",
    "test": "npm run typecheck && npm run test:stage-core",
    "test:stage-core": "npm run build:test && node .tmp-test/test/run-stage-core-tests.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^5.9.3"
  }
}
