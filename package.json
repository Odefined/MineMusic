{
  "name": "minemusic",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:test": "rm -rf .tmp-test && tsc -p tsconfig.test.json",
    "server:minemusic": "npm run build:test && node ./.tmp-test/src/server/index.js",
    "smoke:ncm": "npm run build:test && node ./.tmp-test/test/live/ncm-source-smoke.js",
    "smoke:ncm:library": "npm run build:test && node ./.tmp-test/test/live/ncm-source-library-smoke.js",
    "smoke:ncm:retrieval": "npm run build:test && node ./.tmp-test/test/live/ncm-mixed-retrieval-smoke.js",
    "test": "npm run typecheck && npm run test:stage-core",
    "test:stage-core": "npm run build:test && node ./.tmp-test/test/run-stage-core-tests.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^5.9.3"
  }
}
