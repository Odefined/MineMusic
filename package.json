{
  "name": "minemusic",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:stage-interface-schemas": "node scripts/generate-stage-interface-schemas.mjs",
    "check:stage-interface-schemas": "node scripts/generate-stage-interface-schemas.mjs --check",
    "build:test": "npm run check:stage-interface-schemas && rm -rf .tmp-test && tsc -p tsconfig.test.json",
    "server:minemusic": "npm run build:test && node ./.tmp-test/src/server/index.js",
    "smoke:ncm": "npm run build:test && node ./.tmp-test/test/live/ncm-source-smoke.js",
    "smoke:ncm:library": "npm run build:test && node ./.tmp-test/test/live/ncm-source-library-smoke.js",
    "smoke:library:import": "npm run build:test && node ./.tmp-test/test/live/ncm-library-import-agent-smoke.js",
    "smoke:ncm:retrieval": "npm run build:test && node ./.tmp-test/test/live/ncm-mixed-retrieval-smoke.js",
    "smoke:ncm:matrix": "npm run build:test && node ./.tmp-test/test/live/ncm-real-scenario-matrix.js",
    "smoke:ncm:perf": "npm run build:test && node ./.tmp-test/test/live/ncm-performance-smoke.js",
    "smoke:mcp:stdio": "npm run build:test && node ./.tmp-test/test/live/mcp-stdio-smoke.js",
    "test": "npm run typecheck && npm run test:stage-core",
    "test:stage-core": "npm run build:test && node ./.tmp-test/test/run-stage-core-tests.js",
    "typecheck": "npm run check:stage-interface-schemas && tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  }
}
