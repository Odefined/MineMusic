MINEMUSIC_SERVER_HOST=127.0.0.1
MINEMUSIC_SERVER_PORT=37373
MINEMUSIC_MCP_PATH=/mcp

MINEMUSIC_NETEASE_BASE_URL=http://127.0.0.1:3000
