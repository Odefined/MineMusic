# MINEMUSIC_SOURCE_PROVIDER=fixture_recommendation

MINEMUSIC_MATERIAL_STORE_DB_PATH=/tmp/minemusic/material-store.sqlite
MINEMUSIC_COLLECTION_DB_PATH=/tmp/minemusic/collection.sqlite
MINEMUSIC_LIBRARY_IMPORT_DB_PATH=/tmp/minemusic/library-import.sqlite

MINEMUSIC_HANDBOOK_PATHS=/tmp/minemusic/handbook.md:/tmp/minemusic/handbook-copy.md
